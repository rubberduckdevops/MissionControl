MONGO_USER=missoncontrol
# Production: use a strong random password, e.g. openssl rand -hex 32
MONGO_PASSWORD=changeme
MONGO_DB=missoncontrol
MONGODB_URI=mongodb://${MONGO_USER}:${MONGO_PASSWORD}@mongodb:27017/${MONGO_DB}
MONGODB_DB=${MONGO_DB}
# Production: use a random secret of at least 32 bytes, e.g. openssl rand -hex 32
JWT_SECRET=super-secret-jwt-key-change-in-production
# Production: set to your public domain, e.g. https://example.com
FRONTEND_ORIGIN=http://localhost:3000
# Required to register new operators — share out-of-band.
# Use a strong random value: openssl rand -hex 20
INVITE_CODE=change-me
