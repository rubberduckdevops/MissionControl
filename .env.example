MONGO_USER=missoncontrol
# Production: use a strong random password, e.g. openssl rand -hex 32
MONGO_PASSWORD=changeme
MONGO_DB=missoncontrol
MONGODB_URI=mongodb://${MONGO_USER}:${MONGO_PASSWORD}@mongodb:27017/${MONGO_DB}
MONGODB_DB=${MONGO_DB}
# Production: set to your public domain, e.g. https://example.com
FRONTEND_ORIGIN=http://localhost:3000
# Keycloak OIDC configuration
KEYCLOAK_URL=https://keycloak.example.com
KEYCLOAK_REALM=missioncontrol
KEYCLOAK_CLIENT_ID=missioncontrol-app
# Frontend Keycloak config (Vite env vars)
VITE_KEYCLOAK_URL=https://keycloak.example.com
VITE_KEYCLOAK_REALM=missioncontrol
VITE_KEYCLOAK_CLIENT_ID=missioncontrol-app
# Your GitHub username or org (used to pull pre-built images from GHCR)
GHCR_OWNER=your-github-username
# How often the weather poller contacts NWS (minutes, default: 60)
WEATHER_POLL_INTERVAL_MINUTES=60
